      m_Calls: []
  m_text: "Az Arctic Quest folyam\xE1n pingvinek csapat\xE1t vezeted, akik egy j\xE9ghegyr\u0151l
    cs\xFAsznak lefel\xE9. A hegy l\xE1b\xE1n\xE1l gonosz l\xE9nyek v\xE1rnak r\xE1d,
    akikkel meg kell k\xFCzdened. A pingvinjeidet csatarendbe \xE1ll\xEDthatod a
    LAYOUT men\xFCben, illetve fejlesztheted k\xE9pess\xE9geiket. Az ellens\xE9gek
    legy\u0151z\xE9s\xE9\xE9rt XP pontokat kapsz, amiket felhalmozva szintet l\xE9psz.\n\r\nSok
    sikert, j\xF3 sz\xF3rakoz\xE1st!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
