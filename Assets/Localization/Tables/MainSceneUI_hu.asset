  m_SharedData: {fileID: 11400000, guid: 1b087a8c487126b44a0b1f26ddc913b2, type: 2}
  m_Metadata:
    m_Items:
    - rid: 3130362818983624887
  m_TableData:
  - m_Id: 57742471168
    m_Localized: "Koppints a j\xE1t\xE9khoz!"
    m_Metadata:
      m_Items: []
  - m_Id: 13456329158656
    m_Localized: "\xDAtmutat\xF3"
    m_Metadata:
      m_Items: []
  - m_Id: 13618329956352
    m_Localized: "Kioszt\xE1s"
    m_Metadata:
      m_Items: []
  - m_Id: 13679201890304
    m_Localized: "St\xE1blista"
    m_Metadata:
      m_Items: []
  - m_Id: 14490740994048
    m_Localized: '{0}. szint'
    m_Metadata:
      m_Items:
      - rid: 3130362818983624887
  - m_Id: 15423524843520
    m_Localized: "Fejleszt\xE9si pontok: {0}"
    m_Metadata:
      m_Items:
      - rid: 3130362818983624887
  - m_Id: 21152033943552
    m_Localized: "Az Arctic Quest folyam\xE1n pingvinek csapat\xE1t vezeted, akik
      egy j\xE9ghegyr\u0151l cs\xFAsznak lefel\xE9. A hegy l\xE1b\xE1n\xE1l gonosz
      l\xE9nyek v\xE1rnak r\xE1d, akikkel meg kell k\xFCzdened. A pingvinjeidet csatarendbe
      \xE1ll\xEDthatod a LAYOUT men\xFCben, illetve fejlesztheted k\xE9pess\xE9geiket.
      Az ellens\xE9gek legy\u0151z\xE9s\xE9\xE9rt XP pontokat kapsz, amiket felhalmozva
      szintet l\xE9psz.\n\r\nSok sikert, j\xF3 sz\xF3rakoz\xE1st!"
    m_Metadata:
      m_Items: []
  - m_Id: 26434382344192
    m_Localized: "<align=\"center\">Csuhai Hunor\nGy\xF6nki Dominik\nMocs\xE1ri M\xE1rton\nPerczel
      Patrik</align>\n\n<size=80%>A j\xE1t\xE9kot a GitEgylet csapata k\xE9sz\xEDtette
      a PENdroid 2024 verseny 3. fordul\xF3j\xE1ra.</size>\n\n<size=60%>A projekt
      egy\xE9b, ny\xEDlt licenccel ell\xE1tott nyersanyagokat is felhaszn\xE1l."
    m_Metadata:
      m_Items: []
  - m_Id: 29125900775424
    m_Localized: "Nyelv kiv\xE1laszt\xE1sa"
    m_Metadata:
      m_Items: []
  - m_Id: 29328364023808
    m_Localized: "K\xE9sz"
    m_Metadata:
      m_Items: []
  - m_Id: 62258222215168
    m_Localized: "\xDAjrakezd\xE9s"
    m_Metadata:
      m_Items: []
  - m_Id: 63220475244544
    m_Localized: "Csat\xE1t vesztett\xE9l, \xEDgy a megszerzett XP-pontok fel\xE9t
      kapod meg."
    m_Metadata:
      m_Items: []
  - m_Id: 63792108548096
    m_Localized: "Az \xF6sszes XP-pontot hazaviheted!"
    m_Metadata:
      m_Items: []
  - m_Id: 64822430937088
    m_Localized: "Hurr\xE1!"
    m_Metadata:
      m_Items: []
  - m_Id: 114713052065792
    m_Localized: "Szintl\xE9p\xE9s!"
    m_Metadata:
      m_Items: []
  - m_Id: 114879851147264
    m_Localized: "Feloldott\xE1l egy \xFAj karaktert: {0}"
    m_Metadata:
      m_Items:
      - rid: 3130362818983624887
  - m_Id: 115373768192000
    m_Localized: "{0} fejleszt\xE9si pontot szerezt\xE9l"
    m_Metadata:
      m_Items:
      - rid: 3130362818983624887
  - m_Id: 115832834764800
    m_Localized: Rendben
    m_Metadata:
      m_Items: []
  - m_Id: 124958918848512
    m_Localized: "Gratul\xE1lok, v\xE9gigj\xE1tszottad a j\xE1t\xE9kot! T\xF6r\xF6ld
      az adataidat, hogy \xFAjra \xE1t\xE9lhesd a j\xE1t\xE9k\xE9lm\xE9nyt.\nK\xF6sz\xF6nj\xFCk
      a j\xE1t\xE9kot! :)"
    m_Metadata:
      m_Items: []
